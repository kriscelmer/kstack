#!/usr/bin/env bash
set -euo pipefail

REPO_ROOT="$(cd "$(dirname "$0")" && pwd)"
CODEX_HOME="${CODEX_HOME:-$HOME/.codex}"
CODEX_SKILLS="$CODEX_HOME/skills"
BUN_BIN="${BUN_BIN:-$(command -v bun 2>/dev/null || true)}"
BUN_BIN="${BUN_BIN:-$HOME/.bun/bin/bun}"
LOCAL=0
FORCE=0

while [ $# -gt 0 ]; do
  case "$1" in
    --local) LOCAL=1; shift ;;
    --force) FORCE=1; shift ;;
    --codex-home)
      CODEX_HOME="${2:?Missing value for --codex-home}"
      CODEX_SKILLS="$CODEX_HOME/skills"
      shift 2
      ;;
    --host)
      if [ "${2:-codex}" != "codex" ]; then
        echo "kstack only supports Codex. Ignoring --host ${2:-}." >&2
      fi
      shift 2
      ;;
    -h|--help)
      cat <<'EOF'
Usage: ./setup [--local] [--force] [--codex-home PATH]

Installs kstack into Codex only.

Options:
  --local              Install into ./ .codex/skills for repo-local testing
  --force              Skip confirmation prompts
  --codex-home PATH    Override CODEX_HOME
EOF
      exit 0
      ;;
    *)
      echo "Unknown option: $1" >&2
      exit 1
      ;;
  esac
done

if [ "$LOCAL" -eq 1 ]; then
  CODEX_HOME="$REPO_ROOT/.codex"
  CODEX_SKILLS="$CODEX_HOME/skills"
fi

if [ "$FORCE" -eq 0 ]; then
  echo "Install kstack into: $CODEX_SKILLS"
  printf "Continue? [y/N] "
  read -r reply
  case "$reply" in
    y|Y|yes|YES) ;;
    *) echo "Aborted."; exit 0 ;;
  esac
fi

mkdir -p "$HOME/.kstack" "$HOME/.kstack/projects" "$CODEX_SKILLS"

if [ ! -x "$BUN_BIN" ]; then
  echo "bun not found. Set BUN_BIN or add bun to PATH." >&2
  exit 1
fi

if [ "${KSTACK_SKIP_BUILD:-0}" != "1" ]; then
  if [ ! -x "$REPO_ROOT/browse/dist/browse" ] || [ ! -f "$REPO_ROOT/.agents/skills/kstack/SKILL.md" ]; then
    echo "Building kstack artifacts..."
    (cd "$REPO_ROOT" && "$BUN_BIN" run build)
  else
    (cd "$REPO_ROOT" && "$BUN_BIN" run gen:skill-docs >/dev/null)
  fi
fi

mkdir -p "$REPO_ROOT/.agents/skills/kstack"

# Remove legacy direct subcommand installs. KStack is now routed via `/kstack ...`.
for tmpl in "$REPO_ROOT"/*/SKILL.md.tmpl; do
  [ -f "$tmpl" ] || continue
  skill_name="$(basename "$(dirname "$tmpl")")"
  rm -rf "$CODEX_SKILLS/$skill_name"
done

ln -snf "$REPO_ROOT/.agents/skills/kstack" "$CODEX_SKILLS/kstack"

if [ -f "$HOME/.gstack/config.yaml" ] && [ ! -f "$HOME/.kstack/config.yaml" ]; then
  cp "$HOME/.gstack/config.yaml" "$HOME/.kstack/config.yaml"
fi

touch "$HOME/.kstack/.welcome-seen"

cat <<EOF
kstack ready.
  Codex skills: $CODEX_SKILLS
  Runtime root: $CODEX_SKILLS/kstack
  Canonical state: .kstack/state/<branch>.json
EOF
