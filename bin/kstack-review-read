#!/usr/bin/env bash
# kstack-review-read — read normalized workflow reports for the current branch
set -euo pipefail

SCRIPT_DIR="$(cd "$(dirname "$0")" && pwd)"
eval "$("$SCRIPT_DIR/kstack-slug" 2>/dev/null)"
KSTACK_HOME="${KSTACK_HOME:-${GSTACK_HOME:-$HOME/.kstack}}"
cat "$KSTACK_HOME/projects/$SLUG/$BRANCH-reviews.jsonl" 2>/dev/null || echo "NO_REVIEWS"
echo "---CONFIG---"
"$SCRIPT_DIR/kstack-config" get skip_architecture_lens 2>/dev/null || echo "false"
echo "---HEAD---"
git rev-parse --short HEAD 2>/dev/null || echo "unknown"
