#!/usr/bin/env bash
# kstack-uninstall — remove installed kstack runtime and optional local generated artifacts
set -uo pipefail

if [ -z "${HOME:-}" ]; then
  echo "ERROR: \$HOME is not set" >&2
  exit 1
fi

KSTACK_DIR="${KSTACK_DIR:-$(cd "$(dirname "$0")/.." && pwd)}"
STATE_DIR="${KSTACK_STATE_DIR:-$HOME/.kstack}"
GIT_ROOT="$(git rev-parse --show-toplevel 2>/dev/null || true)"
FORCE=0
KEEP_STATE=0
REMOVE_REPO_RUNTIME=0

while [ $# -gt 0 ]; do
  case "$1" in
    --force) FORCE=1; shift ;;
    --keep-state) KEEP_STATE=1; shift ;;
    --remove-repo-runtime) REMOVE_REPO_RUNTIME=1; shift ;;
    -h|--help)
      sed -n '2,/^[^#]/{ /^#/s/^# \{0,1\}//p; }' "$0"
      exit 0
      ;;
    *)
      echo "Unknown option: $1" >&2
      echo "Usage: kstack-uninstall [--force] [--keep-state] [--remove-repo-runtime]" >&2
      exit 1
      ;;
  esac
done

if [ "$FORCE" -eq 0 ]; then
  echo "This will remove kstack from your system."
  [ -d "$HOME/.codex/skills/kstack" ] && echo "  ~/.codex/skills/kstack"
  [ -d "$STATE_DIR" ] && [ "$KEEP_STATE" -eq 0 ] && echo "  $STATE_DIR"
  if [ -n "$GIT_ROOT" ]; then
    [ -d "$GIT_ROOT/.agents/skills/kstack" ] && [ "$REMOVE_REPO_RUNTIME" -eq 1 ] && echo "  $GIT_ROOT/.agents/skills/kstack"
  fi
  printf "Continue? [y/N] "
  read -r reply
  case "$reply" in
    y|Y|yes|YES) ;;
    *) echo "Aborted."; exit 0 ;;
  esac
fi

REMOVED=()

if [ -d "$HOME/.codex/skills" ]; then
  item="$HOME/.codex/skills/kstack"
  if [ -e "$item" ] || [ -L "$item" ]; then
    rm -rf "$item"
    REMOVED+=("$item")
  fi
fi

if [ -n "$GIT_ROOT" ] && [ "$REMOVE_REPO_RUNTIME" -eq 1 ]; then
  item="$GIT_ROOT/.agents/skills/kstack"
  if [ -e "$item" ] || [ -L "$item" ]; then
    rm -rf "$item"
    REMOVED+=("$item")
  fi
fi

if [ "$KEEP_STATE" -eq 0 ] && [ -d "$STATE_DIR" ]; then
  rm -rf "$STATE_DIR"
  REMOVED+=("$STATE_DIR")
fi

if [ ${#REMOVED[@]} -gt 0 ]; then
  echo "Removed: ${REMOVED[*]}"
  echo "kstack uninstalled."
else
  echo "Nothing to remove."
fi
